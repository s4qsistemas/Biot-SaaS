// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// MODELO CORE SAAS (TENANT)
// ------------------------------------------------------------------
model Empresa {
  id                  Int       @id @default(autoincrement())
  nombre              String    @db.VarChar(255)
  rut                 String    @unique @db.VarChar(20)
  alias               String    @unique @db.VarChar(100)
  giro                String?   @db.VarChar(255)
  direccion           String?   @db.VarChar(255)
  email_contacto      String?   @db.VarChar(255)
  telefono            String?   @db.VarChar(50)
  activo              Boolean   @default(true)
  modulo_naves_activo Boolean?  @default(false)
  fecha_vencimiento   DateTime?
  plan_id             Int?
  logo_url            String?   @db.Text
  plan                Plan?     @relation(fields: [plan_id], references: [id])
  created_at          DateTime  @default(now()) @db.Timestamp(6)
  updated_at          DateTime  @updatedAt @db.Timestamp(6)

  // Relaciones inversas (Un tenant tiene muchos registros de todo)
  usuarios            Usuario[]
  entidades           Entidad[]
  productos           Producto[]
  operarios           Operario[]
  equipos             Equipo[]
  ubicaciones         Ubicacion[]
  cotizaciones        Cotizacion[]
  ordenes_trabajo     OrdenTrabajo[]
  tareas              Tarea[]
  catalogo_tareas     CatalogoTarea[]
  correos_internos    CorreoInterno[]
  unidades_stock      UnidadStock[]
  movimientos         Movimiento[]
  auditorias_empresas AuditoriaEmpresa[]
  naves               Nave[]
}

// ------------------------------------------------------------------
// MODELOS DE NEGOCIO (Con tenant_id inyectado y llaves compuestas)
// ------------------------------------------------------------------

enum Rol {
  super_admin
  admin
  gerente
  jefe_taller
  administrativo
  operario
}

model Usuario {
  id                    Int      @id @default(autoincrement())
  tenant_id             Int
  email                 String   @unique // El email sigue siendo globalmente único para el login
  password              String
  nombre                String
  rol                   Rol      @default(operario)
  cargo                 String?  @db.VarChar(100)
  activo                Boolean  @default(true)
  debe_cambiar_password Boolean  @default(false)
  firma_url             String?  @db.Text
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  empresa               Empresa            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  movimientos           Movimiento[]
  auditorias_realizadas AuditoriaEmpresa[]
  cotizaciones          Cotizacion[] // 👈 Relación inversa
}

model Entidad {
  id              Int       @id @default(autoincrement())
  tenant_id       Int
  nombre          String    @db.VarChar(255)
  rut             String?   @db.VarChar(20)
  tipo            String?   @db.VarChar(20)
  giro            String?   @db.VarChar(255)
  direccion       String?
  comuna          String?   @db.VarChar(100)
  ciudad          String?   @db.VarChar(100)
  email           String?   @db.VarChar(255)
  telefono        String?   @db.VarChar(50)
  contacto_nombre String?   @db.VarChar(255)
  activo          Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  empresa         Empresa        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cotizaciones    Cotizacion[]
  ordenes_trabajo OrdenTrabajo[]
  naves           Nave[]

  @@unique([tenant_id, rut]) // El rut no se puede repetir dentro de la misma empresa
}

model Producto {
  id             Int      @id @default(autoincrement())
  tenant_id      Int
  codigo         String   @db.VarChar(50)
  nombre         String   @db.VarChar(255)
  tipo_medicion  String?  @db.VarChar(20)
  unidad_base    String?  @db.VarChar(10)
  permite_retazo Boolean? @default(false)
  activo         Boolean? @default(true)
  precio_compra  Decimal? @default(0) @db.Decimal(15, 2)
  precio_venta   Decimal? @default(0) @db.Decimal(15, 2)
  stock_minimo   Decimal? @default(0) @db.Decimal(12, 4)

  empresa              Empresa             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  unidades_stock       UnidadStock[]
  detalle_cotizaciones DetalleCotizacion[]

  @@unique([tenant_id, codigo]) // El código de producto es único solo por empresa
}

model Operario {
  id           Int      @id @default(autoincrement())
  tenant_id    Int
  codigo       String?  @db.VarChar(50)
  nombre       String   @db.VarChar(255)
  especialidad String?  @db.VarChar(100)
  valor_hora   Decimal? @default(0) @db.Decimal(10, 2)
  activo       Boolean? @default(true)
  email        String?  @db.VarChar(255)
  celular      String?  @db.VarChar(50)

  empresa              Empresa             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tareas               Tarea[]
  detalle_cotizaciones DetalleCotizacion[]
  registro_tiempo      RegistroTiempo[]

  @@unique([tenant_id, codigo])
}

model Equipo {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  codigo     String?  @db.VarChar(50)
  nombre     String   @db.VarChar(255)
  tipo       String?  @db.VarChar(100)
  valor_hora Decimal  @default(0) @db.Decimal(10, 2)
  ubicacion  String?  @db.VarChar(100)
  activo     Boolean? @default(true)

  empresa              Empresa             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  detalle_cotizaciones DetalleCotizacion[]
  registro_tiempo      RegistroTiempo[]

  @@unique([tenant_id, codigo])
}

model Ubicacion {
  id        Int     @id @default(autoincrement())
  tenant_id Int
  centro    String? @db.VarChar(100)
  bodega    String? @db.VarChar(100)
  ubicacion String? @db.VarChar(100)
  nivel     String? @db.VarChar(50)

  empresa        Empresa       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  unidades_stock UnidadStock[]
}

model Cotizacion {
  id                   Int       @id @default(autoincrement())
  tenant_id            Int
  entidad_id           Int
  nave_id              Int?
  cliente_nombre       String    @db.VarChar(255)
  folio                String?   @db.VarChar(20)
  solicitud_cotizacion String?   @db.VarChar(50)
  folio_externo        String?   @db.VarChar(50)
  fecha_emision        DateTime? @default(now()) @db.Timestamp(6)
  validez_dias         Int?      @default(15)
  monto_neto           Decimal?  @default(0) @db.Decimal(15, 2)
  monto_iva            Decimal?  @default(0) @db.Decimal(15, 2)
  monto_total          Decimal?  @default(0) @db.Decimal(15, 2)
  estado               String?   @db.VarChar(20)
  observaciones        String?
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  imagen_url           String?
  pdf_base64           String?
  logo_url             String?   @db.Text
  firma_url            String?   @db.Text
  fecha_ultimo_envio   DateTime? @db.Timestamp(6)
  motivo_rechazo       String?
  fecha_rechazo        DateTime? @db.Timestamp(6)
  plazo_entrega        String?   @db.VarChar(100)
  descripcion_general  String?   @db.Text

  empresa              Empresa             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entidad              Entidad             @relation(fields: [entidad_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nave                 Nave?               @relation(fields: [nave_id], references: [id], onDelete: NoAction, onUpdate: NoAction) // 👈 Nueva relación
  usuario_id           Int?                // 👈 Quién preparó la cotización
  usuario              Usuario?            @relation(fields: [usuario_id], references: [id])
  detalle_cotizaciones DetalleCotizacion[]
  ordenes_trabajo      OrdenTrabajo[]

  @@unique([tenant_id, folio]) // El folio es único por empresa
}

model DetalleCotizacion {
  id            Int     @id @default(autoincrement())
  cotizacion_id Int // OBLIGATORIO: Físico
  tipo_item     String? @default("servicio") @db.VarChar(20)
  producto_id   Int? // OPCIONAL: Físico
  operario_id   Int? // OPCIONAL: Físico
  equipo_id     Int? // OPCIONAL: Físico
  descripcion   String
  cantidad      Decimal @db.Decimal(12, 4)
  unitario      Decimal @db.Decimal(15, 2)
  total         Decimal @db.Decimal(15, 2)

  // RELACIONES VIRTUALES (Sincronizadas con la obligatoriedad física)
  cotizacion Cotizacion @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  producto   Producto?  @relation(fields: [producto_id], references: [id])
  operario   Operario?  @relation(fields: [operario_id], references: [id])
  equipo     Equipo?    @relation(fields: [equipo_id], references: [id])
}

model OrdenTrabajo {
  id                Int       @id @default(autoincrement())
  tenant_id         Int
  cotizacion_id     Int?
  entidad_id        Int
  folio             String?   @db.VarChar(20)
  cliente_nombre    String?   @db.VarChar(255)
  estado            String?   @db.VarChar(20)
  fecha_inicio      DateTime? @db.Timestamp(6)
  fecha_fin         DateTime? @db.Timestamp(6)
  costo_estimado    Decimal?  @default(0) @db.Decimal(15, 2)
  costo_real        Decimal?  @default(0) @db.Decimal(15, 2)
  precio_venta      Decimal?  @default(0) @db.Decimal(15, 2)
  margen_real       Decimal?  @default(0) @db.Decimal(15, 2)
  margen_porcentaje Decimal?  @default(0) @db.Decimal(5, 2)
  pdf_base64        String?   @db.Text
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)

  empresa            Empresa     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entidad            Entidad     @relation(fields: [entidad_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizacion         Cotizacion? @relation(fields: [cotizacion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tareas             Tarea[]
  horario_programado Json?

  @@unique([tenant_id, folio])
}

model Tarea {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  ot_id              Int?
  operario_id        Int?
  dependencia_id     Int?
  nombre             String    @db.VarChar(255)
  estado             String?   @db.VarChar(20)
  tipo               String?   @db.VarChar(20)
  orden              Int?
  requiere_material  Boolean?  @default(false)
  requiere_documento Boolean?  @default(false)
  observaciones      String?
  fecha_inicio       DateTime? @db.Timestamp(6)
  fecha_fin          DateTime? @db.Timestamp(6)
  fecha_inicio_real  DateTime? @db.Timestamp(6)
  fecha_fin_real     DateTime? @db.Timestamp(6)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  empresa         Empresa          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  orden_trabajo   OrdenTrabajo?    @relation(fields: [ot_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  operario        Operario?        @relation(fields: [operario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tarea_padre     Tarea?           @relation("DependenciaTarea", fields: [dependencia_id], references: [id])
  tareas_hijas    Tarea[]          @relation("DependenciaTarea")
  consumo_ot      ConsumoOt[]
  registro_tiempo RegistroTiempo[]
  pausas_tarea    PausaTarea[]
}

model UnidadStock {
  id                  Int       @id @default(autoincrement())
  tenant_id           Int
  producto_id         Int?
  ubicacion_id        Int?
  es_agregado         Boolean?  @default(false)
  tipo_unit           String?   @db.VarChar(20)
  cantidad_total      Decimal?  @default(1) @db.Decimal(12, 4)
  cantidad_disponible Decimal?  @default(1) @db.Decimal(12, 4)
  cantidad_reservada  Decimal?  @default(0) @db.Decimal(12, 4)
  largo               Decimal?  @db.Decimal(10, 2)
  ancho               Decimal?  @db.Decimal(10, 2)
  espesor             Decimal?  @db.Decimal(10, 2)
  peso                Decimal?  @db.Decimal(10, 2)
  estado              String?   @db.VarChar(20)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)

  empresa     Empresa      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  producto    Producto?    @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ubicacion   Ubicacion?   @relation(fields: [ubicacion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  consumo_ot  ConsumoOt[]
  movimientos Movimiento[]
}

model ConsumoOt {
  id                 Int       @id @default(autoincrement())
  tarea_id           Int?
  unidad_stock_id    Int?
  cantidad_utilizada Decimal   @db.Decimal(12, 4)
  created_at         DateTime? @default(now()) @db.Timestamp(6)

  tarea        Tarea?       @relation(fields: [tarea_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  unidad_stock UnidadStock? @relation(fields: [unidad_stock_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Movimiento {
  id              Int       @id @default(autoincrement())
  tenant_id       Int
  unidad_stock_id Int?
  usuario_id      Int?
  tipo            String?   @db.VarChar(20)
  cantidad_movida Decimal   @db.Decimal(12, 4)
  referencia_tipo String?   @db.VarChar(20)
  referencia_id   Int?
  motivo          String?   @db.Text
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  empresa      Empresa      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  unidad_stock UnidadStock? @relation(fields: [unidad_stock_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario      Usuario?     @relation(fields: [usuario_id], references: [id])
}

model RegistroTiempo {
  id             Int       @id @default(autoincrement())
  tarea_id       Int?
  operario_id    Int?
  equipo_id      Int?
  horas          Decimal?  @db.Decimal(10, 2)
  costo_total    Decimal?  @db.Decimal(15, 2)
  descripcion    String?   @db.Text
  fecha_registro DateTime? @default(now()) @db.Timestamp(6)

  tarea    Tarea?    @relation(fields: [tarea_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  operario Operario? @relation(fields: [operario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  equipo   Equipo?   @relation(fields: [equipo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PausaTarea {
  id                Int       @id @default(autoincrement())
  tarea_id          Int
  motivo            String
  fecha_pausa       DateTime  @default(now()) @db.Timestamp(6)
  fecha_reanudacion DateTime? @db.Timestamp(6)

  tarea Tarea @relation(fields: [tarea_id], references: [id], onDelete: Cascade)
}

model CatalogoTarea {
  id          Int      @id @default(autoincrement())
  tenant_id   Int
  codigo      String   @db.VarChar(50)
  nombre      String   @db.VarChar(255)
  descripcion String?  @db.Text
  activo      Boolean? @default(true)

  empresa Empresa @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, codigo])
}

model CorreoInterno {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  nombre     String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  empresa    String?  @db.VarChar(100)
  telefono   String?  @db.VarChar(50)
  ultimo_uso DateTime @default(now()) @db.Timestamp(6)

  empresa_rel Empresa @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
}

// ------------------------------------------------------------------
// MODELOS DE SUSCRIPCIÓN SAAS
// ------------------------------------------------------------------
model Plan {
  id              Int     @id @default(autoincrement())
  nombre          String  @db.VarChar(50) // Ej: 'Básico', 'Pro', 'Enterprise'
  limite_usuarios Int     @default(5) // Para frenar la creación de empleados si se pasan
  precio_mensual  Decimal @default(0) @db.Decimal(10, 2)
  activo          Boolean @default(true)

  empresas Empresa[] // Un plan puede tener muchas empresas
}

// ------------------------------------------------------------------
// MODELO DE AUDITORÍA Y TRAZABILIDAD
// ------------------------------------------------------------------
model AuditoriaEmpresa {
  id                Int      @id @default(autoincrement())
  empresa_id        Int
  tipo_evento       String   @db.VarChar(50) // Ej: 'CAMBIO_PLAN', 'CAMBIO_ESTADO', 'RESET_CLAVE'
  valor_anterior    String?  @db.Text // Qué había antes (Ej: 'Trial 14 Días')
  valor_nuevo       String?  @db.Text // Qué hay ahora (Ej: 'Pro')
  justificacion     String   @db.Text // Obligatorio para el administrativo
  modificado_por_id Int // ID del SuperAdmin que ejecutó la acción
  created_at        DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  empresa Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [modificado_por_id], references: [id])
}

// ------------------------------------------------------------------
// MODELO DE NAVE
// ------------------------------------------------------------------
model Nave {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  entidad_id  Int?
  nombre      String    @db.VarChar(255)
  descripcion String?   @db.Text
  activo      Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @updatedAt @db.Timestamp(6)

  // Relaciones
  empresa      Empresa      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entidad      Entidad?     @relation(fields: [entidad_id], references: [id], onDelete: SetNull)
  cotizaciones Cotizacion[]

  @@unique([tenant_id, nombre])
}
